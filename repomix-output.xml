                                        <div className={`w-2 h-2 rounded-full ${req.status === 'completed' ? 'bg-green-500' : 'bg-blue-500'}`}></div>
                                        <span className="font-bold text-gray-700">{req.supply?.name}</span>
                                        <span className="text-gray-400">•</span>
                                        <span className="text-gray-500">{req.quantity} {req.supply?.unit}</span>
                                    </div>
                                    <div className="flex items-center gap-4">
                                        <span className="font-bold text-gray-900">₱{parseFloat(req.total_cost).toLocaleString()}</span>
                                        <span className={`text-[10px] px-2 py-0.5 rounded-full font-bold uppercase ${
                                            req.status === 'completed' 
                                                ? 'bg-green-50 text-green-600' 
                                                : 'bg-blue-50 text-blue-600'
                                        }`}>
                                            {req.status.replace('_', ' ')}
                                        </span>
                                    </div>
                                </div>
                            ))}
                        </div>
                    </div>
                </main>
            </div>

            {/* RELEASE MODAL */}
            <Modal show={showReleaseModal} onClose={() => setShowReleaseModal(false)} maxWidth="sm">
                <div className="p-8 text-center">
                    <div className="w-16 h-16 bg-emerald-50 text-emerald-600 rounded-full flex items-center justify-center mx-auto mb-4 border border-emerald-100 shadow-sm">
                        <Wallet size={32} />
                    </div>
                    <h2 className="text-xl font-bold text-gray-900 mb-2">Release Funds?</h2>
                    <p className="text-sm text-gray-500 mb-6 leading-relaxed">
                        Are you sure you want to authorize the release of <span className="font-bold text-gray-900">₱{Number(selectedRequest?.total_cost).toLocaleString()}</span> for <strong>{selectedRequest?.supply?.name}</strong>?
                        <br/><br/>
                        This will notify <strong>Procurement</strong> to proceed with the purchase.
                    </p>
                    <div className="flex justify-center gap-3">
                        <button 
                            onClick={() => setShowReleaseModal(false)}
                            className="px-5 py-2.5 text-gray-500 font-bold hover:bg-gray-50 rounded-xl transition"
                        >
                            Cancel
                        </button>
                        <button 
                            onClick={handleRelease}
                            className="px-6 py-2.5 bg-gray-900 text-white rounded-xl font-bold hover:bg-gray-800 transition shadow-lg shadow-gray-200 active:scale-95"
                        >
                            Confirm Release
                        </button>
                    </div>
                </div>
            </Modal>

            {/* REJECT MODAL */}
            <Modal show={showRejectModal} onClose={() => setShowRejectModal(false)} maxWidth="sm">
                <div className="p-8 text-center">
                    <div className="w-16 h-16 bg-red-50 text-red-600 rounded-full flex items-center justify-center mx-auto mb-4 border border-red-100 shadow-sm">
                        <XCircle size={32} />
                    </div>
                    <h2 className="text-xl font-bold text-gray-900 mb-2">Reject Release?</h2>
                    <p className="text-sm text-gray-500 mb-6 leading-relaxed">
                        Do you really want to reject the fund release for <strong>{selectedRequest?.supply?.name}</strong>? 
                        This action cannot be undone.
                    </p>

                    <div className="text-left mb-6">
                        <label className="text-xs font-bold text-gray-700 uppercase tracking-wider mb-1 block">Reason for Rejection</label>
                        <textarea 
                            className="w-full border-gray-300 rounded-xl text-sm focus:border-red-500 focus:ring-red-500 shadow-sm transition resize-none"
                            rows={3}
                            placeholder="e.g., Insufficient funds, Request needs revision..."
                            value={rejectReason}
                            onChange={(e) => setRejectReason(e.target.value)}
                            required
                        />
                    </div>
                    <div className="flex justify-center gap-3">
                        <button 
                            onClick={() => setShowRejectModal(false)}
                            className="px-5 py-2.5 text-gray-500 font-bold hover:bg-gray-50 rounded-xl transition"
                        >
                            Dismiss
                        </button>
                        <button 
                            onClick={handleReject}
                            className="px-6 py-2.5 bg-red-600 text-white rounded-xl font-bold hover:bg-red-700 transition shadow-lg shadow-red-100 active:scale-95"
                        >
                            Confirm Rejection
                        </button>
                    </div>
                </div>
            </Modal>
            {/* PAYROLL RELEASE MODAL */}
            <Modal show={showPayrollReleaseModal} onClose={() => setShowPayrollReleaseModal(false)} maxWidth="sm">
                <div className="p-8 text-center">
                    <div className="w-16 h-16 bg-indigo-50 text-indigo-600 rounded-full flex items-center justify-center mx-auto mb-4 border border-indigo-100 shadow-sm">
                        <Wallet size={32} />
                    </div>
                    <h2 className="text-xl font-bold text-gray-900 mb-2">Release Payroll?</h2>
                    <p className="text-sm text-gray-500 mb-6 leading-relaxed">
                        Authorize payment of <span className="font-bold text-gray-900">₱{Number(selectedPayroll?.total_amount).toLocaleString()}</span> for <span className="font-bold">{selectedPayroll?.month}</span>?
                        <br/>
                        <span className="text-xs text-gray-400">Funds will be deducted from your Available Balance.</span>
                    </p>
                    <div className="flex justify-center gap-3">
                        <button 
                            onClick={() => setShowPayrollReleaseModal(false)}
                            className="px-5 py-2.5 text-gray-500 font-bold hover:bg-gray-50 rounded-xl transition"
                        >
                            Cancel
                        </button>
                        <button 
                            onClick={handleReleasePayroll}
                            className="px-6 py-2.5 bg-indigo-600 text-white rounded-xl font-bold hover:bg-indigo-700 transition shadow-lg shadow-indigo-200 active:scale-95"
                        >
                            Confirm Payment
                        </button>
                    </div>
                </div>
            </Modal>

            {/* PAYROLL REJECT MODAL */}
            <Modal show={showPayrollRejectModal} onClose={() => setShowPayrollRejectModal(false)} maxWidth="sm">
                <div className="p-8 text-center">
                    <div className="w-16 h-16 bg-red-50 text-red-600 rounded-full flex items-center justify-center mx-auto mb-4 border border-red-100 shadow-sm">
                        <XCircle size={32} />
                    </div>
                    <h2 className="text-xl font-bold text-gray-900 mb-2">Reject Payroll?</h2>
                    <p className="text-sm text-gray-500 mb-6">
                        This will mark the payroll as <span className="font-bold text-red-600">Rejected</span>. HR will need to delete or regenerate it.
                    </p>
                    <div className="flex justify-center gap-3">
                        <button 
                            onClick={() => setShowPayrollRejectModal(false)}
                            className="px-5 py-2.5 text-gray-500 font-bold hover:bg-gray-50 rounded-xl transition"
                        >
                            Cancel
                        </button>
                        <button 
                            onClick={handleRejectPayroll}
                            className="px-6 py-2.5 bg-red-600 text-white rounded-xl font-bold hover:bg-red-700 transition shadow-lg shadow-red-100 active:scale-95"
                        >
                            Confirm Reject
                        </button>
                    </div>
                </div>
            </Modal>
            {/* TOAST NOTIFICATION */}
            {showToast && (
                <div className={`fixed bottom-4 right-4 px-6 py-4 rounded-xl shadow-2xl flex items-center gap-3 z-50 animate-slide-up ${
                    toastType === 'success' ? 'bg-gray-900/95 text-white' : 'bg-red-500 text-white'
                }`}>
                    {toastType === 'success' ? <CheckCircle size={20} className="text-emerald-400" /> : <AlertCircle size={20} />}
                    <p className="font-bold text-sm tracking-wide">{toastMessage}</p>
                </div>
            )}
        </div>
    );
}
