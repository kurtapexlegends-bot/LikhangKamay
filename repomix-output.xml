} from 'lucide-react';

// --- HELPER COMPONENTS ---
const KPICard = ({ title, value, icon: Icon, color, bg, trend }) => (
    <div className="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm hover:shadow-lg hover:border-gray-200 transition-all duration-300">
