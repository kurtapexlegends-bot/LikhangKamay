                        {/* REVENUE */}
                        <div className="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm relative overflow-hidden group hover:shadow-md transition duration-300">
                             <div className="flex justify-between items-start mb-4 relative z-10">
