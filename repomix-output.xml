        ]);

        $this->actingAs($seller)
            ->post(route('orders.update', $order->order_number), [
                'status' => 'Accepted',
            ])
            ->assertRedirect();

        $order->refresh();

        $this->assertSame('Accepted', $order->status);
        $this->assertNotNull($order->accepted_at);

        $this->actingAs($seller)
            ->get(route('chat.index', ['user_id' => $buyer->id]))
