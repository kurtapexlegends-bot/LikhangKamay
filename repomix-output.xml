                                        {related.sold > 0 && (
                                            <span className="text-[10px] text-gray-400">{related.sold} sold</span>
                                        )}
                                    </div>
                                </div>
                            </Link>
                        ))}
                    </div>
                </div>
            )}
        </ShopLayout>
    );
}
