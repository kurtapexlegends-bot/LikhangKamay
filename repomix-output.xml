                                    <Banknote size={24} />
                                </div>
                                <span className="text-[10px] uppercase font-bold text-emerald-600 bg-emerald-50 px-2 py-1 rounded-full border border-emerald-100">
                                    Total Revenue
                                </span>
                             </div>
