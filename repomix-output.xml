            </div>

            {platformWallet && (
                <div className="mb-8 grid grid-cols-1 gap-6 xl:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)]">
                    <div className="rounded-2xl border border-emerald-100 bg-emerald-50 p-5 shadow-sm">
