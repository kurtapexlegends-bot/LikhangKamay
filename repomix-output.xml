        return_reason: '',
        return_proof_image: null,
    });

    const [previewUrl, setPreviewUrl] = useState(null);

    React.useEffect(() => {
        if (!isOpen) {
            reset();
            clearErrors();
            setPreviewUrl(null);
        }
    }, [isOpen]);

    const handleFileChange = (e) => {
        const file = e.target.files[0];
