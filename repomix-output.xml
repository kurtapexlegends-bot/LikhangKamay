                                                        Release Funds
                                                    </button>
                                                    <button 
                                                        onClick={() => {
                                                            setSelectedRequest(req);
                                                            setShowRejectModal(true);
                                                        }}
                                                        className="px-4 py-2 bg-white border border-gray-200 text-gray-500 text-xs font-bold rounded-xl hover:bg-gray-50 transition active:scale-95"
                                                    >
                                                        Reject
                                                    </button>
                                            </div>
                                        </div>
                                    </div>
                                ))
                            ) : (
                                <div className="p-12 text-center text-gray-400">
                                    <CheckCircle size={48} className="mx-auto mb-4 text-gray-200" />
                                    <p>No pending requests. You're all caught up!</p>
                                </div>
                            )}
                        </div>
                    </div>

                    {/* HISTORY */}
                    <div className="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden opacity-75 grayscale hover:grayscale-0 hover:opacity-100 transition-all duration-300">
