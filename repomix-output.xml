            'seller.module' => \App\Http\Middleware\EnsureSellerModuleAccess::class,
            'staff.security' => \App\Http\Middleware\EnsureStaffSecurityGate::class,
        ]);
        
    })
    ->withExceptions(function (Exceptions $exceptions): void {
        //
    })->create();
