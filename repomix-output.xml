                                <h3 className="font-bold text-gray-900 text-lg">Release History</h3>
                            </div>
                        </div>
                        <div className="divide-y divide-gray-50 max-h-60 overflow-y-auto">
                            {history.map(req => (
                                <div key={req.id} className="p-4 flex items-center justify-between text-sm">
