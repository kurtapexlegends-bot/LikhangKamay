    onRatingChange,
    onMaterialChange,
    onLocationChange,
    onClearAll,
    className = ''
}) {
    // Rating options
    const ratingOptions = [
        { value: '', label: 'Any Rating' },
        { value: '4', label: '4★ & Up' },
        { value: '3', label: '3★ & Up' },
