                                                                    msg.sender === 'me' 
                                                                    ? 'bg-gradient-to-br from-clay-500 to-clay-600 text-white rounded-br-md' 
                                                                    : 'bg-white text-gray-700 border border-gray-100 rounded-bl-md'
