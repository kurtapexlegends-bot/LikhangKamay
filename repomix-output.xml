                    disabled={processing}
                >
                    {processing ? (
                        <Loader2 size={20} className="animate-spin" />
                    ) : (
                        <>
                            <KeyRound size={18} className="mr-2" />
                            Reset Password
                        </>
                    )}
                </PrimaryButton>
            </form>

            <p className="mt-6 text-center text-xs text-gray-400">
                Your password will be updated immediately after submission.
            </p>
        </GuestLayout>
    );
}
