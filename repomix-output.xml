                            <p className="text-sm text-gray-600 mt-0.5">
                                <span className="font-bold text-amber-700">{metrics.pendingSponsorships}</span> sponsorship request{metrics.pendingSponsorships > 1 ? "s" : ""} awaiting your approval.
                            </p>
                        </div>
                    </div>
                    <Link
