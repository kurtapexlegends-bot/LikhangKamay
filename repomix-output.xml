                                if (file) {
                                    setData('avatar', file);
                                    setData('preview_url', URL.createObjectURL(file));
                                }
                            }}
                        />
                    </div>
                    
                    <div className="flex-1 text-center sm:text-left space-y-2">
                        <div>
                            <h3 className="text-sm font-bold text-gray-900">Profile Photo</h3>
