                                                {/* Messages */}
                                                <div className="space-y-3">
                                                    {messages.map((msg) => (
                                                        <div key={msg.id} className={`flex ${msg.sender === 'me' ? 'justify-end' : 'justify-start'}`}>
                                                            <div className={`max-w-[75%] group`}>
