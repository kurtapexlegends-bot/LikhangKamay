import { 
    Package, Search, AlertCircle, Cuboid, 
    TrendingUp, X, Tag, Image as ImageIcon,
    AlertTriangle, ChevronUp, ChevronDown,
    User, LogOut, Menu, MoreVertical, RotateCcw,
